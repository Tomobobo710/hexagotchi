## 7. Handler Implementation

### Phase 1: Button click handler
Replace the placeholder lambda so each button routes through one handler:
```cpp
btn->setOnClick([this, label]() { handleGotchiAction(label); });
```

### Phase 2: Action handler (updated — mood overlays + shader trigger included)
```cpp
void GotchiScene::handleGotchiAction(const std::string& action) {
    if (!gotchi || gotchi->isDead()) {
        lastClickedButton_ = "Cannot interact - Gotchi is dead";
        buttonFeedbackTimer_ = 1.5f;
        return;
    }
    // Sleeping guard: only "Give a Break" (to wake) is allowed while asleep
    if (gotchi->isSleeping() && action != "Give a Break") {
        lastClickedButton_ = "Gotchi is sleeping - give a break to wake";
        buttonFeedbackTimer_ = 1.5f;
        return;
    }

    float& cooldown = buttonCooldowns_[action];
    if (cooldown > 0.0f) {
        lastClickedButton_ = "Wait - Cooldown: " +
            std::to_string(static_cast<int>(cooldown) + 1) + "s";
        buttonFeedbackTimer_ = 1.0f;
        return;
    }

    auto& stats = gotchi->getStats();
    auto& mood  = gotchi->getMood();
    std::string feedback;
    int   shaderMode = -1;
    float shaderDur  = 0.0f;
    bool  success    = true;

    if (action == "Wash") {
        gotchi->clean();
        stats.addStat(EmotionalStat::SATISFACTION, 5.0f);
        mood.addMoodOverlay(GotchiMoodType::MOOD_13_CALM, 5.0f);
        mood.addMoodOverlay(GotchiMoodType::MOOD_14_PEACEFUL, 8.0f);
        feedback = "Washed - Cleanliness 100%";
        shaderMode = 0; shaderDur = 1.5f;
    } else if (action == "Groom") {
        gotchi->interact();
        stats.addStat(EmotionalStat::HAPPINESS, 10.0f);
        stats.addStat(EmotionalStat::FRIEDNSHIP, 2.0f); // NOTE: enum is misspelled
        mood.addMoodOverlay(GotchiMoodType::MOOD_10_JOYFUL, 5.0f);
        mood.addMoodOverlay(GotchiMoodType::MOOD_52_BEAUTIFUL, 10.0f);
        feedback = "Groomed - Happy & shiny!";
        shaderMode = 1; shaderDur = 3.0f;
    } else if (action == "Feed") {
        gotchi->feed();
        stats.addStat(EmotionalStat::SATISFACTION, 5.0f);
        mood.addMoodOverlay(GotchiMoodType::MOOD_02_SATISFIED, 10.0f);
        mood.addMoodOverlay(GotchiMoodType::MOOD_13_CALM, 5.0f);
        feedback = "Fed - Hunger reduced";
        shaderMode = 2; shaderDur = 3.0f;
    } else if (action == "Pet") {
        gotchi->interact();
        stats.addStat(EmotionalStat::HAPPINESS, 10.0f);
        stats.addStat(EmotionalStat::LOVE, 5.0f);
        stats.addStat(EmotionalStat::FRIEDNSHIP, 3.0f); // NOTE: enum is misspelled
        mood.addMoodOverlay(GotchiMoodType::MOOD_10_JOYFUL, 8.0f);
        mood.addMoodOverlay(GotchiMoodType::MOOD_30_LOVING, 15.0f);
        feedback = "Petted - Happiness up";
        shaderMode = 3; shaderDur = 2.0f;
    } else if (action == "Play") {
        gotchi->play();
        // No manual ENERGY change here: verify play() drain first (see 4.1)
        mood.addMoodOverlay(GotchiMoodType::MOOD_01_EXCITED, 8.0f);
        mood.addMoodOverlay(GotchiMoodType::MOOD_31_PLAYFUL, 5.0f);
        feedback = "Played - Energetic!";
        shaderMode = 4; shaderDur = 4.0f;
    } else if (action == "Give a Break") {
        if (gotchi->isSleeping()) {
            gotchi->wake();  // wake() already applies +Happiness per its declaration
            mood.addMoodOverlay(GotchiMoodType::MOOD_12_RELIEVED, 5.0f);
            feedback = "Woke up - Refreshed";
        } else {
            gotchi->sleep();
            mood.addMoodOverlay(GotchiMoodType::MOOD_13_CALM, 6.0f);
            feedback = "Resting - Restoring energy";
        }
        shaderMode = 5; shaderDur = 2.0f;
    } else {
        success = false;
    }

    if (success) {
        lastClickedButton_ = feedback;
        buttonFeedbackTimer_ = 3.0f;
        cooldown = 2.0f;
        if (shaderMode >= 0) triggerActionShader(shaderMode, shaderDur);
        // TODO: hidden-driver deltas here once storage exists (section 5)
    }
}
```

### Phase 3: Cooldown + feedback timers (in `update()`)
```cpp
for (auto& [name, timer] : buttonCooldowns_) if (timer > 0.0f) timer -= deltaTime;
if (buttonFeedbackTimer_ > 0.0f) {
    buttonFeedbackTimer_ -= deltaTime;
    if (buttonFeedbackTimer_ <= 0.0f) lastClickedButton_.clear();
}
if (actionOverlayTimer_ > 0.0f) actionOverlayTimer_ -= deltaTime;
```

### Phase 4: Button cooldown visual (in `draw()`)
```cpp
for (auto& btn : buttons) {
    float cd = buttonCooldowns_[btn->getLabel()];
    if (cd > 0.0f) {
        Color overlay = {0,0,0,(unsigned char)std::min(160.0f, cd*80.0f)};
        DrawRectangle(btn->getX(), btn->getY(), btn->getWidth(), btn->getHeight(), overlay);
    }
    btn->draw();
}
```

### New member variables (`GotchiScene.hpp`)
```cpp
std::map<std::string, float> buttonCooldowns_;
float buttonFeedbackTimer_ = 0.0f;
// shader overlay members from section 6.5
```

